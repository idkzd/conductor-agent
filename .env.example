# === Root / shared ===
# For demo you can run without keys (uses powerful mock reasoning)

# === LLM (used by Conductor + sub-agents) ===
# Prefer Anthropic Claude 3.5 Sonnet / Opus or xAI Grok for best reasoning
ANTHROPIC_API_KEY=sk-ant-...
# Or OpenAI compatible:
OPENAI_API_KEY=sk-...
# xAI:
XAI_API_KEY=xai-...

# === On-chain (agents + deployer) ===
# Private key that will call DecisionLogger.logDecision (use a burner for hackathon)
DEPLOYER_PRIVATE_KEY=0x...

# Optional second key for ERC-8004 Reputation giveFeedback (distinct from agent owner to bypass self-feedback guard)
DEMO_REVIEWER_PK=0x...

# For mantle-agent-kit-sdk (Pyth live + full DeFi tool-calls): set one of above + optional APP_ID from https://mantle-devkit.vercel.app
# APP_ID=... (enables platform validation in SDK init)

MANTLE_RPC=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz

# After deploy:
DECISION_LOGGER_ADDRESS=0x...

# === Frontend (Vercel) ===
NEXT_PUBLIC_MANTLE_RPC=https://rpc.mantle.xyz
NEXT_PUBLIC_DECISION_LOGGER=0x...

# Mantlescan API key for verification (optional but recommended)
MANTLESCAN_API_KEY=

# Real LLM via OpenRouter (free tier possible, server-side only)
# OPENROUTER_API_KEY=sk-or-...
# Model example: openrouter/owl-alpha (or any free model)

# The frontend demo calls /api/run-conductor which runs the real (improved) Conductor logic.
# No keys needed for full demo experience.
